/* 自定义导航栏样式 */
.custom-navbar {
  display: flex;
  align-items: center; /* 垂直居中 */
  justify-content: center; /* 左对齐（图标在左，标题居中） */ 
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);  /* 给顶部添加阴影 */
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;  /* 确保浮于页面其他内容之上 */
  height: 120rpx;
  width: 100%;
  padding-top: 60rpx;  /* todo ios如何呢，我擦可能需要兼容各种机型。*/
}

/* 标题居中 */
.navbar-center { 
  display: flex;
  justify-content: center;
  align-items: center; /* 垂直居中 */
  margin: 0rpx 40rpx;
}

.navbar-center .title {
  font-size: 35rpx;
  color: #000;
}

.hamburger-menu {
  position: absolute;
  left: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  width: 40rpx;
  height: 35rpx;
  cursor: pointer;
}

.hamburger-line {
  height: 6rpx;
  background-color: #000;
  border-radius: 2px;
}
