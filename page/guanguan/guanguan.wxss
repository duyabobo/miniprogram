.page {
  display: flex;
  flex-direction: column;
  align-items: center; 
}

.container {
  padding-bottom: 70px; /* 添加 padding 以防内容被按钮遮挡 */
  width: 100%;
}

.guan {
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx;
  margin: 30rpx 0rpx;
  background-color: #FFFFFF;
  width: 100%;
  box-sizing: border-box;
}

.img,
.img-default {
  width: 500rpx;
  height: 250rpx;
  margin: 10rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5; /* Set default background color */
}

.address-time-status {
  display: flex;
  width: 500rpx;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  padding: 0 20rpx;
}

.info,
.info-default {
  display: flex;
  width: 100%; /* Make width 100% to occupy full width of the column */
  flex-direction: row;
  align-items: center;
}

.info-default {
  background-color: #f5f5f5; /* Set default background color */
}

.info-img {
  width: 35rpx;
  height: 35rpx;
  padding-right: 5rpx;
}

.address {
  font-size: 30rpx;
  color: gray;
}

.time {
  font-size: 35rpx;
}

/* 使录音按钮固定在底部，宽度为屏幕宽度 */
.footer {
  position: fixed;
  bottom: 0;
  width: 100vw;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  z-index: 1000; /* 确保浮于页面其他内容之上 */
}

.record-button {
  width: 100%;
  height: 100%;
  background-color: #ffffff;
  color: white;
  font-size: 16px;
  display: flex;
  justify-content: center;
  align-items: center;
}